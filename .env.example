# Application
APP_NAME=llmops-chat
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# GGUF model (host path mounted into container at MODEL_PATH)
MODEL_PATH=/models/qwen3-4b-q4_k_m.gguf
MODEL_N_CTX=2048
MODEL_N_THREADS=4
LAZY_LOAD_MODEL=true

# Langfuse (traces + evaluation scores)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# OpenTelemetry → OTel Collector → Prometheus / Jaeger / etc.
OTEL_ENABLED=true
OTEL_SERVICE_NAME=llmops-chat
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Prometheus metrics (scraped from /metrics)
METRICS_ENABLED=true

# Evaluation quality gates (CI)
EVAL_API_BASE_URL=http://localhost:8000
EVAL_MIN_AVG_SCORE=0.9
EVAL_MAX_P95_LATENCY_MS=2000
EVAL_DATASET_PATH=evaluation/dataset.json
