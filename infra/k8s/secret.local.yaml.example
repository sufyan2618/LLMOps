# Copy this to secret.local.yaml (gitignored) and fill real keys, then:
#   kubectl apply -f k8s/secret.local.yaml
apiVersion: v1
kind: Secret
metadata:
  name: llmops-chat-secrets
  namespace: llmops
type: Opaque
stringData:
  LANGFUSE_PUBLIC_KEY: "pk-lf-CHANGE_ME"
  LANGFUSE_SECRET_KEY: "sk-lf-CHANGE_ME"
